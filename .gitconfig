[user]
    name = Giorgio Mendieta
    email = 31053658+GiorgioMendieta@users.noreply.github.com
	signingkey = /Users/giorgio/.ssh/id_ed25519.pub

[include]
    # Delta diff viewer theme
    path = ~/.dotfiles/Apps/delta/themes.gitconfig

[init]
    defaultBranch = main

[color]
    ui = auto

[alias]
    # List available aliases
    aliases = !git config --get-regexp alias | sed -re 's/alias\\.(\\S*)\\s(.*)$/\\1 = \\2/g'
    # Display tree-like log, because default log is a pain…
    lg = log --graph --date=relative --pretty=tformat:'%Cred%h%Creset -%C(auto)%d%Creset %s %Cblue(%an - %C(bold)%ad)%Creset' -10
    cm = commit -m
    cam = commit -am
    st = status -sb
    co = checkout

[core]
    excludesfile = ~/.gitignore_global
    editor = nvim
    pager = delta

[interactive]
    diffFilter = delta --color-only

[delta]
    # cf. path in [include] for the list of available themes    
    # features = mellow-barbet
    features = arctic-fox
    navigate = true
    line-numbers = true
    true-color = always

[merge]
    conflictstyle = diff3

[fetch]
    # Automatically remove remote tracking branches that no longer exist
    prune = true

[pull]
    rebase = true

[diff]
    colorMoved = default

[commit]
	gpgsign = true

[gpg]
	format = ssh
